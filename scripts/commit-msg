#!/usr/bin/env bash
# commit-msg hook — strips AI-injected trailers from commit messages.
# Installed by scripts/install-hooks.sh. Do NOT bypass with --no-verify.

COMMIT_MSG_FILE="$1"

if [ ! -f "$COMMIT_MSG_FILE" ]; then
  exit 0
fi

# Patterns to strip (case-insensitive, whole-line matches):
#   Made-with: <tool>
#   Co-authored-by: <AI tool name or email containing cursor/codex/copilot/chatgpt/claude>
#   Generated-by: / Written-by: <AI tool>
sed -i -E \
  -e '/^Made-with:/Id' \
  -e '/^Co-authored-by:.*\b(cursor|codex|copilot|chatgpt|claude|openai|anthropic)\b/Id' \
  -e '/^Generated-by:/Id' \
  -e '/^Written-by:/Id' \
  "$COMMIT_MSG_FILE"

# Remove trailing blank lines left after stripping
sed -i -e :a -e '/^\n*$/{$d;N;ba' -e '}' "$COMMIT_MSG_FILE"

exit 0
