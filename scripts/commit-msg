#!/usr/bin/env bash
# commit-msg hook — strips AI-injected trailers from commit messages.
# Installed by scripts/install-hooks.sh. Do NOT bypass with --no-verify.

set -euo pipefail

COMMIT_MSG_FILE="${1:-}"

if [ -z "$COMMIT_MSG_FILE" ] || [ ! -f "$COMMIT_MSG_FILE" ]; then
  exit 0
fi

# Patterns to strip (case-insensitive, whole-line matches):
#   Made-with: <tool>
#   Co-authored-by: <AI tool name or email containing cursor/codex/copilot/chatgpt/claude/openai/anthropic>
#   Generated-by: / Written-by: <AI tool>
# Implemented in perl because BSD (macOS) and GNU sed disagree on -i, the
# /I address flag, and \b word boundaries; perl behaves the same everywhere.
perl -0777 -i -pe '
  s/^Made-with:.*\n?//gim;
  s/^Co-authored-by:.*\b(?:cursor|codex|copilot|chatgpt|claude|openai|anthropic)\b.*\n?//gim;
  s/^Generated-by:.*\n?//gim;
  s/^Written-by:.*\n?//gim;
  s/\s+\z/\n/;
' "$COMMIT_MSG_FILE"
