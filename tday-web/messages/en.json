  "terms": {
    "title": "Terms of Service",
    "lastUpdated": "Last updated: January 19, 2026",
    "intro": "By using T'Day (the “Service”), you agree to these Terms of Service.",
    "sections": {
      "1": {
        "title": "Use of the Service",
        "content": "T'Day is a free productivity app for managing todos, notes, and files. You agree to use the Service lawfully and not abuse or disrupt it."
      },
      "2": {
        "title": "Accounts",
        "content": "You are responsible for keeping your account secure and all activity under your account. Information must be accurate."
      },
      "3": {
        "title": "Your Content",
        "content": "You retain ownership of your content. By using T'Day, you grant permission to store and process it only to operate the Service."
      },
      "4": {
        "title": "Acceptable Use",
        "content": [
          "No illegal, harmful, or malicious content",
          "No accessing other users’ data",
          "No abusing infrastructure",
          "No unlawful use of the Service"
        ]
      },
      "5": {
        "title": "Availability",
        "content": "T'Day is a personal service provided on a best-effort basis. The Service may change, go offline, or be discontinued at any time."
      },
      "6": {
        "title": "Termination",
        "content": "You may stop using T'Day at any time. We may suspend access if these Terms are violated."
      },
      "7": {
        "title": "Disclaimer",
        "content": "T'Day is provided “as is”. We are not responsible for data loss, interruptions, or damages resulting from use of the Service."
      },
      "8": {
        "title": "Changes",
        "content": "We may update these Terms. Continued use means you accept the changes."
      },
      "9": {
        "title": "Contact",
        "content": "Questions? Email support"
      }
    }
  },
  "privacy": {
    "title": "Privacy Policy",
    "lastUpdated": "Last updated: January 19, 2026",
    "intro": "T'Day (“we”, “our”, or “us”) is a personal productivity app. This Privacy Policy explains what data we collect and how we use it.",
    "sections": {
      "1": {
        "title": "Information We Collect",
        "content": [
          "Account data: email address and time zone",
          "User content: todos, notes, and encrypted files",
          "Technical data: IP address, browser and session info",
          "Cookies and local storage for authentication"
        ]
      },
      "2": {
        "title": "How We Use Your Data",
        "content": [
          "Provide and operate T'Day",
          "Authenticate users",
          "Store and sync your content",
          "Maintain security and prevent abuse"
        ]
      },
      "3": {
        "title": "Data Storage & Security",
        "content": "T'Day uses NextAuth for authentication, NeonDB for storage, and Vercel for hosting. Files are encrypted where applicable. While no system is perfectly secure, reasonable steps are taken to protect your data."
      },
      "4": {
        "title": "Sharing of Data",
        "content": "We only share data with service providers required to operate T'Day. We do not sell your personal data."
      },
      "5": {
        "title": "Cookies",
        "content": "Cookies and local storage are used for login sessions, preferences, and security. Disabling cookies may affect functionality."
      },
      "6": {
        "title": "Data Retention",
        "content": "We keep your data while your account is active. You may delete your account at any time and your content will be removed within a reasonable period."
      },
      "7": {
        "title": "Your Rights",
        "content": "You may access, correct, delete, or export your data using the app features."
      },
      "8": {
        "title": "Changes",
        "content": "We may update this policy from time to time. Updates will appear on this page."
      },
      "9": {
        "title": "Contact",
        "content": "Questions? Email support"
      }
    }
  },
