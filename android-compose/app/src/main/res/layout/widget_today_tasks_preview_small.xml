<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_preview_background"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="@drawable/widget_preview_accent_strip"
        android:includeFontPadding="false"
        android:text="" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="13dp"
        android:paddingTop="6dp"
        android:paddingEnd="13dp"
        android:paddingBottom="7dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_app"
                    android:includeFontPadding="false"
                    android:text="6"
                    android:textColor="@color/tday_widget_today_accent"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_app"
                    android:includeFontPadding="false"
                    android:text="@string/widget_today_tasks_count_unit"
                    android:textColor="@color/tday_widget_on_surface_variant"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/widget_add_button_background">

                <ImageView
                    android:layout_width="17dp"
                    android:layout_height="17dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/widget_add_icon_today" />
            </FrameLayout>
        </LinearLayout>

        <TextView
            android:layout_width="1dp"
            android:layout_height="4dp"
            android:includeFontPadding="false"
            android:text="" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="22dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="2dp"
            android:paddingEnd="2dp">

            <ImageView
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:contentDescription="@null"
                android:src="@drawable/widget_priority_dot_medium" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:fontFamily="@font/nunito_app"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="Plan the morning"
                android:textColor="@color/tday_widget_on_surface"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="22dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito_app"
                android:includeFontPadding="false"
                android:text="+5 more"
                android:textColor="@color/tday_widget_today_accent"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
