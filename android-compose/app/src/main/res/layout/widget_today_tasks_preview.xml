<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_preview_background"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="@drawable/widget_preview_accent_strip"
        android:includeFontPadding="false"
        android:text="" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="6dp"
        android:paddingEnd="14dp"
        android:paddingBottom="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:fontFamily="@font/nunito_app"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="@string/widget_today_tasks_title"
                android:textColor="@color/tday_widget_on_surface"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:fontFamily="@font/nunito_app"
                android:gravity="center"
                android:includeFontPadding="false"
                android:minWidth="48dp"
                android:text="6 due"
                android:textColor="@color/tday_widget_today_accent"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="48dp"
                android:layout_height="44dp"
                android:background="@drawable/widget_add_button_background"
                android:fontFamily="@font/nunito_app"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="+"
                android:textColor="@color/tday_widget_today_accent"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:contentDescription="@null"
                android:src="@drawable/widget_priority_dot_medium" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:fontFamily="@font/nunito_app"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="Plan the morning"
                android:textColor="@color/tday_widget_on_surface"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:fontFamily="@font/nunito_app"
                android:includeFontPadding="false"
                android:text="9:00 AM"
                android:textColor="@color/tday_widget_on_surface_variant"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:contentDescription="@null"
                android:src="@drawable/widget_priority_dot_high" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:fontFamily="@font/nunito_app"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="Review today"
                android:textColor="@color/tday_widget_on_surface"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:fontFamily="@font/nunito_app"
                android:includeFontPadding="false"
                android:text="10:00 AM"
                android:textColor="@color/tday_widget_on_surface_variant"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
