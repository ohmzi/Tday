<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_preview_background"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="@drawable/widget_preview_accent_strip"
        android:includeFontPadding="false"
        android:text="" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="8dp"
        android:paddingEnd="14dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:fontFamily="@font/nunito_app"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="@string/widget_today_tasks_title"
                android:textColor="@color/tday_widget_on_surface"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:background="@drawable/widget_today_count_pill_background"
                android:fontFamily="@font/nunito_app"
                android:gravity="center"
                android:includeFontPadding="false"
                android:minWidth="56dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="6 due"
                android:textColor="@color/tday_widget_today_accent"
                android:textSize="12sp"
                android:textStyle="bold" />

            <FrameLayout
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/widget_add_button_background">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/widget_add_icon_today" />
            </FrameLayout>
        </LinearLayout>

        <TextView
            android:layout_width="1dp"
            android:layout_height="6dp"
            android:includeFontPadding="false"
            android:text="" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="25dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="2dp"
            android:paddingEnd="2dp">

            <ImageView
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:contentDescription="@null"
                android:src="@drawable/widget_priority_dot_medium" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:fontFamily="@font/nunito_app"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="Plan the morning"
                android:textColor="@color/tday_widget_on_surface"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="22dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/widget_due_time_chip_background"
                android:fontFamily="@font/nunito_app"
                android:gravity="center"
                android:includeFontPadding="false"
                android:paddingStart="7dp"
                android:paddingEnd="7dp"
                android:text="9:00 AM"
                android:textColor="@color/tday_widget_on_surface_variant"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="25dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito_app"
                android:includeFontPadding="false"
                android:text="+5 more"
                android:textColor="@color/tday_widget_today_accent"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
