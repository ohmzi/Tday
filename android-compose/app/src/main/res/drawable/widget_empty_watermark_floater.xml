            android:strokeColor="@color/tday_widget_floater_accent"
            android:strokeLineCap="round"
            android:strokeLineJoin="round" />
        <path
            android:pathData="M2,21c0,-3 1.85,-5.36 5.08,-6C9.5,14.52 12,13 13,12"
