    "T'Day can save this server URL securely on this device so you can reuse it during setup." : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "T'Day puede guardar esta URL del servidor de forma segura en este dispositivo para que puedas reutilizarla durante la configuración." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "T'Day peut enregistrer cette URL de serveur en toute sécurité sur cet appareil afin que vous puissiez la réutiliser lors de la configuration." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "T'Day kann diese Server-URL sicher auf diesem Gerät speichern, damit du sie bei der Einrichtung wiederverwenden kannst." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "T'Day può salvare questo URL del server in modo sicuro su questo dispositivo per riutilizzarlo durante la configurazione." } },
        "pt" : { "stringUnit" : { "state" : "translated", "value" : "O T'Day pode salvar esta URL do servidor com segurança neste dispositivo para que você possa reutilizá-la durante a configuração." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "T'Day может безопасно сохранить этот URL сервера на устройстве, чтобы вы могли использовать его при настройке." } },
